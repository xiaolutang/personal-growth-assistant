# 前端配置
FRONTEND_BASE_PATH=/growth/

# Neo4j 配置
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here

# LLM 配置
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=glm-5

# LangSmith 可观测性（可选）
# 获取 API Key: https://smith.langchain.com/settings/password
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=personal-growth-assistant

# 日志服务配置
LOG_SERVICE_URL=http://localhost:8001

# CORS 配置
# 逗号分隔的允许域名列表（不要使用通配符 *）
# 开发环境示例: http://localhost:3000,http://localhost
# 生产环境示例: https://your-domain.com
ALLOWED_ORIGINS_ENV=http://localhost:3000,http://localhost
